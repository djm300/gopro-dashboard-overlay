<layout>
    <composite x="16" y="16" name="date_time">
        <frame width="240" height="76" bg="0,0,0,110" cr="22" opacity="0.55"/>
        <component type="text" x="18" y="14" size="16" outline="0,0,0" outline_width="2">DATE</component>
        <component type="datetime" x="18" y="34" format="%Y/%m/%d" size="22" outline="0,0,0" outline_width="2"/>
        <component type="datetime" x="18" y="54" format="%H:%M:%S" size="18" outline="0,0,0" outline_width="2"/>
    </composite>

    <composite x="16" y="112" name="peak_speed">
        <frame width="600" height="170" bg="0,0,0,76" cr="26" opacity="0.42"/>
        <component type="text" x="18" y="14" size="18" outline="0,0,0" outline_width="2">PEAK SPEED</component>
        <translate x="16" y="40">
            <component type="chart" name="speed_peak_chart" width="560" height="110" seconds="180" samples="512" metric="speed" units="kph" fill="0,191,255,110" line="0,191,255,230" text="255,255,255,180" bg="0,0,0,0" marker-size="10"/>
        </translate>
    </composite>

    <composite x="16" y="300" name="altitude_graph">
        <frame width="600" height="170" bg="0,0,0,76" cr="26" opacity="0.42"/>
        <component type="text" x="18" y="14" size="18" outline="0,0,0" outline_width="2">ALTITUDE</component>
        <translate x="16" y="40">
            <component type="chart" name="altitude_chart" width="560" height="110" seconds="180" samples="512" metric="alt" units="metre" fill="255,159,28,95" line="255,159,28,220" text="255,255,255,180" bg="0,0,0,0" marker-size="10"/>
        </translate>
    </composite>

    <component type="moving_map" name="moving_map" x="640" y="27" size="600" zoom="17" opacity="0.32" corner_radius="0"/>

    <composite x="1000" y="6" name="speed">
        <frame width="256" height="57" bg="0,0,0,64" cr="11" opacity="0.45"/>
        <component type="text" x="10" y="6" size="9" outline="0,0,0" outline_width="1">KPH</component>
        <component type="icon" x="215" y="3" file="gauge.png" size="37"/>
        <component type="metric" x="10" y="19" metric="speed" units="kph" dp="0" size="29" outline="0,0,0" outline_width="2"/>
    </composite>

    <composite x="1000" y="73" name="elevation">
        <frame width="256" height="50" bg="0,0,0,48" cr="9" opacity="0.40"/>
        <component type="text" x="10" y="6" size="9" outline="0,0,0" outline_width="1">ELE</component>
        <component type="icon" x="212" y="3" file="mountain.png" size="40"/>
        <component type="metric" x="10" y="19" metric="alt" units="metre" dp="0" size="25" outline="0,0,0" outline_width="2"/>
    </composite>

    <composite x="1000" y="135" name="slope">
        <frame width="256" height="50" bg="0,0,0,48" cr="9" opacity="0.40"/>
        <component type="text" x="10" y="6" size="9" outline="0,0,0" outline_width="1">SLOPE</component>
        <component type="icon" x="212" y="3" file="slope-triangle.png" size="40"/>
        <component type="metric" x="10" y="19" metric="gradient" dp="0" size="25" outline="0,0,0" outline_width="2"/>
    </composite>

    <composite x="1000" y="257" name="temperature">
        <frame width="256" height="50" bg="0,0,0,48" cr="9" opacity="0.40"/>
        <component type="text" x="10" y="6" size="9" outline="0,0,0" outline_width="1">TEMP</component>
        <component type="icon" x="212" y="3" file="thermometer.png" size="40"/>
        <component type="metric" x="10" y="19" metric="temp" units="degC" dp="0" size="25" outline="0,0,0" outline_width="2"/>
    </composite>

    <composite x="1000" y="324" name="distance">
        <frame width="256" height="50" bg="0,0,0,48" cr="9" opacity="0.40"/>
        <component type="text" x="10" y="6" size="9" outline="0,0,0" outline_width="1">DISTANCE</component>
        <component type="icon" x="212" y="3" file="ruler.png" size="40"/>
        <component type="metric" x="10" y="19" metric="odo" units="metre" dp="0" size="25" outline="0,0,0" outline_width="2"/>
    </composite>

    <composite x="1000" y="413" name="path">
        <frame width="256" height="327" bg="0,0,0,40" cr="9" opacity="0.30"/>
        <component type="text" x="10" y="6" size="9" outline="0,0,0" outline_width="1">PATH</component>
        <translate x="13" y="23">
            <component type="cairo-circuit-map" size="230" line-width="0.04" loc-size="0.08" loc-fill="255,0,0,180" loc-outline="0,0,0,0"/>
        </translate>
    </composite>
</layout>
