<layout>
    <composite x="3070" y="18" name="speed">
        <frame width="700" height="170" bg="0,0,0,64" cr="32" opacity="0.45"/>
        <component type="text" x="30" y="18" size="28" outline="0,0,0" outline_width="4">KPH</component>
        <component type="icon" x="575" y="8" file="gauge.png" size="110"/>
        <component type="metric" x="30" y="56" metric="speed" units="kph" dp="0" size="88" outline="0,0,0" outline_width="5"/>
    </composite>

    <composite x="3070" y="220" name="elevation">
        <frame width="700" height="150" bg="0,0,0,48" cr="28" opacity="0.40"/>
        <component type="text" x="30" y="18" size="28" outline="0,0,0" outline_width="4">ELE</component>
        <component type="icon" x="566" y="8" file="mountain.png" size="120"/>
        <component type="metric" x="30" y="56" metric="alt" units="metre" dp="0" size="76" outline="0,0,0" outline_width="5"/>
    </composite>

    <composite x="3070" y="404" name="slope">
        <frame width="700" height="150" bg="0,0,0,48" cr="28" opacity="0.40"/>
        <component type="text" x="30" y="18" size="28" outline="0,0,0" outline_width="4">SLOPE</component>
        <component type="icon" x="566" y="8" file="slope-triangle.png" size="120"/>
        <component type="metric" x="30" y="56" metric="gradient" dp="0" size="76" outline="0,0,0" outline_width="5"/>
    </composite>

    <composite x="3070" y="772" name="distance">
        <frame width="700" height="150" bg="0,0,0,48" cr="28" opacity="0.40"/>
        <component type="text" x="30" y="18" size="28" outline="0,0,0" outline_width="4">DISTANCE</component>
        <component type="icon" x="566" y="8" file="ruler.png" size="120"/>
        <component type="metric" x="30" y="56" metric="odo" units="metre" dp="0" size="76" outline="0,0,0" outline_width="5"/>
    </composite>

    <composite x="3070" y="980" name="path">
        <frame width="700" height="980" bg="0,0,0,40" cr="28" opacity="0.30"/>
        <component type="text" x="30" y="18" size="28" outline="0,0,0" outline_width="4">PATH</component>
        <translate x="40" y="70">
            <component type="cairo-circuit-map" size="620" line-width="0.04" loc-size="0.08" loc-fill="255,0,0,180" loc-outline="0,0,0,0"/>
        </translate>
    </composite>
</layout>
