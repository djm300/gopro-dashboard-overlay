<layout>
    <!-- Date & time -->
    <composite x="24" y="18" name="date_time">
        <frame width="306" height="92" bg="18,22,30,182" cr="46" opacity="0.64" outline="255,255,255,18" fo="20"/>
        <component type="datetime" x="153" y="38" format="%d-%m-%Y" size="24" outline="0,0,0" outline_width="1" align="mm"/>
        <component type="datetime" x="153" y="62" format="%H:%M:%S" size="24" outline="0,0,0" outline_width="1" align="mm"/>
    </composite>

    <!-- Top bar - speed indicator -->
    <composite x="416" y="18" name="speed">
        <frame width="306" height="92" bg="18,22,30,160" cr="46" opacity="0.62" outline="255,255,255,16" fo="16"/>
        <component type="icon" x="5" y="26" file="gauge.png" size="40"/>
        <component type="metric" x="153" y="46" metric="speed" units="kph" dp="0" size="54" align="mm" outline="0,0,0" outline_width="1"/>
        <component type="text" x="280" y="84" size="24" align="rb" outline="0,0,0" outline_width="1">km/h</component>
    </composite>

    <!-- Top bar - elevation -->
    <composite x="808" y="18" name="elevation">
        <frame width="306" height="92" bg="18,22,30,160" cr="46" opacity="0.62" outline="255,255,255,16" fo="16"/>
        <component type="icon" x="5" y="26" file="mountain.png" size="40"/>
        <component type="metric" x="153" y="46" metric="alt" units="metre" dp="0" size="54" align="mm" outline="0,0,0" outline_width="1"/>
        <component type="text" x="280" y="84" size="24" align="rb" outline="0,0,0" outline_width="1">m</component>
    </composite>

    <!-- Top bar - slope decline -->
    <composite x="1200" y="18" name="slope">
        <frame width="306" height="92" bg="18,22,30,160" cr="10" opacity="0.62" outline="255,255,255,16" fo="16"/>
        <component type="icon" x="5" y="26" file="slope-triangle.png" size="40"/>
        <component type="metric" x="153" y="46" metric="gradient" dp="0" size="54" align="mm" outline="0,0,0" outline_width="1"/>
        <component type="text" x="280" y="84" size="24" align="rb" outline="0,0,0" outline_width="1">%</component>
    </composite>

    <!-- Top bar - distance -->
    <composite x="1592" y="18" name="distance">
        <frame width="306" height="92" bg="18,22,30,160" cr="10" opacity="0.62" outline="255,255,255,16" fo="16"/>
        <component type="icon" x="5" y="26" file="ruler.png" size="40"/>
        <component type="metric" x="153" y="46" metric="odo" units="metre" dp="0" size="54" align="mm" outline="0,0,0" outline_width="1"/>
        <component type="text" x="280" y="84" size="24" align="rb" outline="0,0,0" outline_width="1">m</component>
    </composite>

    <!-- Peak speed -->
    <composite x="26" y="634" name="peak_speed">
        <frame width="438" height="206" bg="16,20,28,168" cr="10" opacity="0.3" outline="255,255,255,18" fo="0"/>
        <component type="icon" x="116" y="0" file="gauge-20.png" size="206"/>
        <component type="chart" name="speed_peak_chart" width="438" height="206" seconds="180" samples="512" metric="speed" units="kph" fill="0,122,255,96" line="0,122,255,235" text="255,255,255,190" bg="0,0,0,0" marker-size="5"/>
    </composite>

    <!-- Altitude graph -->
    <composite x="26" y="856" name="altitude_graph">
        <frame width="438" height="206" bg="16,20,28,168" cr="10" opacity="0.3" outline="255,255,255,18" fo="0"/>
        <component type="icon" x="116" y="0" file="mountain-20.png" size="206"/>
        <component type="chart" name="altitude_chart" width="438" height="206" seconds="180" samples="512" metric="alt" units="metre" fill="48,209,88,88" line="48,209,88,235" text="255,255,255,190" bg="0,0,0,0" marker-size="5"/>
    </composite>

    <!-- Path -->
    <composite x="1456" y="856" name="path">
        <frame width="438" height="206" bg="16,20,28,164" cr="10" opacity="0.3" outline="255,255,255,18" fo="0"/>
        <translate x="116" y="0">
            <component type="cairo-circuit-map" size="206" fill="255,255,255,235" outline="178,186,198,180" line-width="0.05" loc-size="0.02" loc-fill="255,0,0,255" loc-outline="0,0,0,255"/>
        </translate>
    </composite>
</layout>
